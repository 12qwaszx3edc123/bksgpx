type ErrorResponse struct {
	Code      int         `json:"code"`
	SubCode   string      `json:"subCode,omitempty"`
	Message   string      `json:"message"`
	Details   interface{} `json:"details,omitempty"`
	TraceId   string      `json:"traceId,omitempty"`
	RequestId string      `json:"requestId,omitempty"`
}

func (h *{{.UpperName}}Handler) errorResponse(c *gin.Context, httpStatus int, code int, subCode string, message string, err error) {
	requestID, _ := c.Get("requestID")
	traceId, _ := c.Get("traceId")
	resp := ErrorResponse{
		Code:      code,
		SubCode:   subCode,
		Message:   message,
		TraceId:   traceId.(string),
		RequestId: requestID.(string),
	}
	if err != nil {
		resp.Message = err.Error()
	}
	c.JSON(httpStatus, resp)
}

func (h *{{.UpperName}}Handler) Create(c *gin.Context) {
	requestID, _ := c.Get("requestID")
	start := time.Now()

	log.Printf("create request start: method=%s, path=%s, requestID=%v", c.Request.Method, c.Request.URL.Path, requestID)

	req := &pb.Create{{.UpperName}}Req{}
	if err := c.ShouldBindJSON(req); err != nil {
		log.Printf("create request bind failed: %v", err)
		h.errorResponse(c, http.StatusBadRequest, 1001, "FIELD_VALIDATION_FAILED", "请求参数错误", err)
		return
	}

	resp, err := h.client.Create(c.Request.Context(), req)
	if err != nil {
		log.Printf("create RPC failed: %v", err)
		h.errorResponse(c, http.StatusInternalServerError, 5001, "SYSTEM_ERROR", "系统繁忙，请稍后再试", err)
		return
	}

	log.Printf("create request success: requestID=%v, duration=%s", requestID, time.Since(start))

	c.JSON(http.StatusCreated, resp)
}

